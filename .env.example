# o4c environment variables
# Copy to .env and fill in your values: cp .env.example .env

# Discord bot token (required for Discord channel)
# Create at https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=

# Comma-separated Discord channel IDs to respond in (empty = all channels)
DISCORD_CHANNEL_IDS=

# Channel ID for heartbeat alerts (defaults to first DISCORD_CHANNEL_IDS entry)
DISCORD_HEARTBEAT_CHANNEL_ID=

# Heartbeat check interval in ms (default: 300000 = 5 min)
HEARTBEAT_INTERVAL_MS=300000

# Dashboard password (default: changeme)
DASHBOARD_PASSWORD=

# GitHub personal access token (optional, for self-upgrade from private repo)
GITHUB_TOKEN=
